{
  "name": "jiaotang-planet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:validate": "tsx scripts/content/validateArticles.mts",
    "build:data": "npm run build:validate && tsx scripts/content/buildCosmosData.mts && tsx scripts/content/buildSearchIndex.mts && tsx scripts/content/buildExternalArticles.mts",
    "build:articles": "mkdir -p public/articles && cp content/articles/*.md public/articles/",
    "build:seo": "tsx scripts/content/buildSeoPages.mts",
    "build": "npm run build:data && npm run build:articles && vite build && npm run build:seo",
    "preview": "vite preview",
    "ai:suggest": "tsx scripts/content/aiSuggest.mts",
    "refresh:content": "node --import tsx scripts/content/external/refresh.mts"
  },
  "dependencies": {
    "@extractus/article-extractor": "^8.0.20",
    "@react-three/fiber": "^9.1.2",
    "@supabase/supabase-js": "^2.102.1",
    "d3-force": "^3.0.0",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "three": "^0.175.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.175.0",
    "@vitejs/plugin-react": "^4.5.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
